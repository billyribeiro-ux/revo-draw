{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		// Import the real `.ts` / `.svelte.ts` source extension directly (TS 6 + bundler resolution).
		// Compatible with `noEmit` (inherited from the SvelteKit tsconfig); no `.js` rewrite-on-emit
		// needed because Vite/Rolldown bundles, it never tsc-emits. Stops editors flagging `.js`
		// specifiers that have no on-disk counterpart.
		"allowImportingTsExtensions": true,
		// Mirror Excalidraw's own compiler strictness (packages/tsconfig.base.json: `strict: true`
		// only) for the vendored port. `strict` + zero-`any` is the floor we keep; the extra flags
		// below were LayoutForge-era additions the vendored Excalidraw tree isn't written for
		// (every `arr[i]` would become `T | undefined`). Re-enable for greenfield code later.
		"noUncheckedIndexedAccess": false,
		"noImplicitOverride": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"exactOptionalPropertyTypes": false,
		"types": ["node", "vite/client", "unplugin-icons/types/svelte"]
	}
	// Paths/includes/excludes are managed by the SvelteKit-generated tsconfig we extend.
}
