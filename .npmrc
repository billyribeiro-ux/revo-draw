# esbuild's ignored build script is expected (Vite 8 uses Rolldown). Don't let the
# ignored-builds notice escalate to a fatal error during tooling-triggered installs.
strict-dep-builds=false
# Don't auto-run `pnpm install` (and its build-script gate) on every pnpm-invoked
# command. We manage installs explicitly; this keeps `svelte-kit sync` etc. fast.
verify-deps-before-run=false
