{
  "name": "layoutforge",
  "version": "0.1.0",
  "description": "Local-first semantic layout / wireframe tool that exports Claude-Code-ready Markdown specs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest-svelte.config.ts",
    "test:pure": "vitest run --config vitest.config.ts",
    "test:runes": "vitest run --config vitest-svelte.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "tauri": "tauri",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@braintree/sanitize-url": "6.0.2",
    "@excalidraw/laser-pointer": "1.3.1",
    "@iconify/utils": "3.1.3",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-sql": "2.4.0",
    "drizzle-orm": "0.45.2",
    "es6-promise-pool": "2.5.0",
    "lodash.throttle": "4.1.1",
    "nanoid": "3.3.3",
    "perfect-freehand": "1.2.0",
    "points-on-curve": "1.0.1",
    "roughjs": "4.6.4",
    "tinycolor2": "1.6.0"
  },
  "devDependencies": {
    "@iconify-json/ph": "1.2.2",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tauri-apps/cli": "2.11.2",
    "@types/lodash.throttle": "4.1.9",
    "@types/node": "25.9.1",
    "@types/react": "19.2.2",
    "@types/tinycolor2": "1.4.6",
    "drizzle-kit": "0.31.10",
    "svelte": "5.55.0",
    "svelte-check": "4.4.8",
    "typescript": "6.0.3",
    "unplugin-icons": "23.0.1",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=20"
  }
}
